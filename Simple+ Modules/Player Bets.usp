	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Street";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num2;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Street";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num3;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("Current Bet Index: %d", CurrentBetArrayIndex);
	//AddToTotalBet(NewBet);
	
	//Update Player Bank
	UpdatePlayerBank();
}

//Add LINE Bet to Bet Structure
Function AddLineBet (Integer Num1, Integer Num2, Integer Num3, Integer Num4, Integer Num5, Integer Num6){
Trace("Storing Line bet Index:%d with Numbers:%d, %d, %d, %d, %d, and %d, with Bet:%d",CurrentBetArrayIndex, Num1, Num2, Num3, Num4, Num5, Num6, StringBetToAnalog());
	
