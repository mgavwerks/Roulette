	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Line";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num2;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Line";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num3;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	PlayerBets[CurrentBetArrayIndex].BetType = "Line";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num4;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Line";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num5;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Line";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num6;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("Current Bet Index: %d", CurrentBetArrayIndex);
	
	//Update Player Bank
	UpdatePlayerBank();
}

Function PlaceBet(String PlaceBetType, Integer Index)
{
   If(BetsRemaining > 0){
	If(PlayerBank != 0 && BetAmount <= PlayerBank){
	Switch(Index)
	{
		Case(1):{
			if (PlaceBetType = "Split"){
				AddSplitBet(1,2);
			}
			else if (PlaceBetType = "Straight"){
				AddStraightBet(Index);
			}
			else if (PlaceBetType = "Corner"){
				AddCornerBet(1,2,4,5);
			}
			else if (PlaceBetType = "Street"){
				AddStreetBet(1,2,3);
			}
			else if (PlaceBetType = "Line"){
				AddLineBet(1,2,3,4,5,6);
			}
			
			AddToTotalBet(StringBetToAnalog());
		}
		
		Case(2):{
			if (PlaceBetType = "Split"){
				AddSplitBet(2,3);
			}
			else if (PlaceBetType = "Straight"){
				AddStraightBet(Index);
			}
			else if (PlaceBetType = "Corner"){
				AddCornerBet(2,3,5,6);
			}
			else if (PlaceBetType = "Street"){
				AddStreetBet(4,5,6);
			}
			else if (PlaceBetType = "Line"){
				AddLineBet(4,5,6,7,8,9);
			}
			
			AddToTotalBet(StringBetToAnalog());
		}
		
		Case(3):{
			if (PlaceBetType = "Split"){
			AddSplitBet(1,4);
			}
			else if (PlaceBetType = "Straight"){
				AddStraightBet(Index);
			}
			else if (PlaceBetType = "Corner"){
				AddCornerBet(4,5,7,8);
			}
			else if (PlaceBetType = "Street"){
				AddStreetBet(7,8,9);
			}
			else if (PlaceBetType = "Line"){
				AddLineBet(7,8,9,10,11,12);
			}
			
			AddToTotalBet(StringBetToAnalog());
		}
		
		Case(4):
		{
			if (PlaceBetType = "Split"){
			AddSplitBet(2,5);
			}
			else if (PlaceBetType = "Straight"){
				AddStraightBet(Index);
			}
			else if (PlaceBetType = "Corner"){
				AddCornerBet(5,6,8,9);
			}
			else if (PlaceBetType = "Street"){
				AddStreetBet(10,11,12);
			}
			else if (PlaceBetType = "Line"){
