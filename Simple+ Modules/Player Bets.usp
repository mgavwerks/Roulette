Function PlaceOutsideBet(Integer BetNumber, String Position) {

	If(PlayerBank != 0 && BetAmount <= PlayerBank){
	PlayerBets[CurrentBetArrayIndex].BetType = "Outside";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = BetNumber;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	Trace("Placing Outside Bet: %s on Index: %d with value: %d", Position, CurrentBetArrayIndex,StringBetToAnalog()); 
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	AddToTotalBet(StringBetToAnalog());
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("Current Bet Index: %d", CurrentBetArrayIndex);
	
	//Update Player Bank
	UpdatePlayerBank();
	} 
	Else {DisplayMessage(1);}
}


/*******************************************************************************************
  Event Handlers
*******************************************************************************************/
/* Start Inside Bet Events */
PUSH StraightBet {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();
  
	PlaceBet("Straight", ModifiedArray);
}

PUSH SplitBet {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();

	PlaceBet("Split", ModifiedArray);
}

PUSH CornerBet {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();

	PlaceBet("Corner", ModifiedArray);
}

PUSH StreetBet {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();

	PlaceBet("Street", ModifiedArray);
}

PUSH LineBet {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();

	PlaceBet("Line", ModifiedArray);
}

/* Start Outside Bet Events */

PUSH BetLow {    
    PlaceOutsideBet(40,"Low");
}

PUSH BetHigh {
	PlaceOutsideBet(41,"High");
}

PUSH BetEven {
	PlaceOutsideBet(42,"Even");
}

PUSH BetOdd {
	PlaceOutsideBet(43,"Odd");
}

PUSH BetBlack {
	PlaceOutsideBet(44,"Black");}

PUSH BetRed {
	PlaceOutsideBet(45,"Red");
}

PUSH BetColumn {
	Integer ModifiedArray;
	ModifiedArray = GetLastModifiedArrayIndex();
	
	PlayerBets[CurrentBetArrayIndex].BetType = "Outside";
	
	Switch(ModifiedArray){
		Case(1):{PlaceOutsideBet(46,"Column 1");}
		Case(2):{PlaceOutsideBet(47,"Column 2");}
		Case(3):{PlaceOutsideBet(48,"Column 3");}
		Default:{}
	}
	
}

PUSH BetFirstTwelve {
	PlaceOutsideBet(49,"First Twelve");
}

PUSH BetSecondTwelve {
	PlaceOutsideBet(50,"Second Twelve");
}

PUSH BetThirdTwelve {
	PlaceOutsideBet(51,"Third Twelve");
}

PUSH BetZero {
	PlaceOutsideBet(0,"Zero");
}

PUSH BetDblZero {
	PlaceOutsideBet(37,"Dbl Zero");
}


/* Start Other Events */

PUSH ClearBets
{
	CurrentBetArrayIndex = 1;
	PlayerTotalBet = 0;
	TotalBet = 0;
	BetsRemaining = 50;
	
}

PUSH ResetGame
{
	CurrentBetArrayIndex = 1;
	PlayerBank = 1000;
	PlayerBankOut = PlayerBank;
	TotalBet = 0;
	BetsRemaining = 50;
	BetCount = BetsRemaining;
	Pulse(200,ResetPushed);
}

CHANGE	WinningNumber
{
integer WinNum;
integer i;
integer payout;

WinNum = WinningNumber;
trace("winning number chosen: %d",WinNum);

	for(i = 1 to CurrentBetArrayIndex - 1){
	
		Trace("Player bets: %s, %d", PlayerBets[i].BetType, PlayerBets[i].NumberPlayed);
	
		if( PlayerBets[i].BetType = "Straight" && PlayerBets[i].NumberPlayed = WinNum){
		payout = payout + PlayerBets[i].BetAmount * 35;
		}
		
		if (PlayerBets[i].BetType = "Split" && PlayerBets[i].NumberPlayed = WinNum){
		payout = payout + PlayerBets[i].BetAmount * 17;
		}
		
		if (PlayerBets[i].BetType = "Corner" && PlayerBets[i].NumberPlayed = WinNum){
		payout = payout + PlayerBets[i].BetAmount * 8;
		}
		
		if (PlayerBets[i].BetType = "Street" && PlayerBets[i].NumberPlayed = WinNum){
		payout = payout + PlayerBets[i].BetAmount * 11;
		}
		
		if (PlayerBets[i].BetType = "Line" && PlayerBets[i].NumberPlayed = WinNum){
		payout = payout + PlayerBets[i].BetAmount * 5;
		}
		
		if (PlayerBets[i].BetType = "Outside"){
		
			If(WinNum <=18 && WinNum != 0 && PlayerBets[i].NumberPlayed = 40){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If(WinNum >=19 && WinNum <=36 && PlayerBets[i].NumberPlayed = 41){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If(NumEven = 1 && PlayerBets[i].NumberPlayed = 42){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If(NumOdd = 1 && PlayerBets[i].NumberPlayed = 43){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If(NumBlack = 1 && PlayerBets[i].NumberPlayed = 44){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If(NumRed = 1 && PlayerBets[i].NumberPlayed = 45){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumColumn[1] = 1 && PlayerBets[i].NumberPlayed = 46){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumColumn[2] = 1 && PlayerBets[i].NumberPlayed = 47){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumColumn[3] = 1 && PlayerBets[i].NumberPlayed = 48){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumFirstTwelve = 1 && PlayerBets[i].NumberPlayed = 49){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumSecondTwelve = 1 && PlayerBets[i].NumberPlayed = 50){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumThirdTwelve = 1 && PlayerBets[i].NumberPlayed = 51){
				payout = payout + PlayerBets[i].BetAmount * 2;
			}
			
			If (NumZero = 1 && PlayerBets[i].NumberPlayed = WinNum){
				payout = payout + PlayerBets[i].BetAmount * 35;
			}
			
			If (NumDblZero = 1 && PlayerBets[i].NumberPlayed = WinNum){
				payout = payout + PlayerBets[i].BetAmount * 35;
			}
			
		}
	Trace("Index %d payout is:%d", i, payout);		
	}
	
	ReturnPreviousWinners(WinNum);
	
	PlayerWinnings = payout;
	PlayerBank = PlayerBank + payout;
	PlayerBankOut = PlayerBank;
	BetsRemaining = 50;
	BetCount = BetsRemaining;
}

CHANGE BetAmount$ {
StringBetToAnalog();
}


