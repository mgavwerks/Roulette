/*******************************************************************************************
  DIGITAL, ANALOG and SERIAL INPUTS and OUTPUTS
*******************************************************************************************/
ANALOG_INPUT	WinningNumber;
DIGITAL_INPUT	ClearBets,
				ResetGame,
				NumFirstTwelve,
				NumSecondTwelve,
				NumThirdTwelve,
				NumEven,
				NumOdd,
				NumRed,
				NumBlack,
				NumHigh,
				NumLow,
				NumZero,
				NumDblZero,
				BetLow,
				BetFirstTwelve,
				BetEven,
				BetSecondTwelve,
				BetRed,
				BetBlack,
				BetThirdTwelve,
				BetOdd,
				BetHigh,	
				BetZero,
				BetDblZero,
				NumColumn[3],
				BetColumn[3],
				StraightBet[36],
				SplitBet[57],
				LineBet[11],
				StreetBet[12],
				CornerBet[22];
String_INPUT	BetAmount$[5]; 
// STRING_INPUT 
// BUFFER_INPUT 
STRING_OUTPUT	ErrorMessage;
DIGITAL_OUTPUT	DisplayErrorMessage,
				ResetPushed; 
ANALOG_OUTPUT	PlayerBankOut,
				PlayerTotalBet,
				PlayerWinnings,
				BetCount,
				PrevWin[5];
	

/*******************************************************************************************
  Parameters
*******************************************************************************************/

/*******************************************************************************************
  Structure Definitions
*******************************************************************************************/
STRUCTURE BetStructure
{
String	BetType[8];
Integer	NumberPlayed;
Integer BetAmount;
};

BetStructure PlayerBets[50];

/*******************************************************************************************
  Global Variables
*******************************************************************************************/
INTEGER CurrentBetArrayIndex,
		TotalBet,
		PlayerBank,
		BetAmount,
		BetsRemaining,
		PrevWinIndex;
STRING	PlaceBetType[8];

/*******************************************************************************************
  Functions
*******************************************************************************************/
//Converts Serial bet amount to integer
Integer_Function StringBetToAnalog()			
{
	Integer bet;
	BetAmount = atoi(BetAmount$);
	return (BetAmount);
}

//Displays total player bets from BetStructure
Function AddToTotalBet(Integer Bet)
{			
    TotalBet = TotalBet + Bet;
    PlayerTotalBet = TotalBet;
}

Function ReturnPreviousWinners(Integer Winner){
 PrevWin[PrevWinIndex] = Winner;
 PrevWinIndex = PrevWinIndex + 1;
 
 If(PrevWinIndex = 6){
 	PrevWinIndex = 1;
 }
}

Function DisplayMessage(Integer MsgNum){
	Switch(MsgNum)
	{
		Case(1):
			{
				ErrorMessage = "Not enough bank. Please adjust your bet or reset the game";
				Pulse(200,DisplayErrorMessage);
			}
		Case(2):
			{
				ErrorMessage = "You do not have any bets remaining.";
				Pulse(200,DisplayErrorMessage);
			}
		Default:{}
	}
		
}

/***********************************
Bet Managing Functions
***********************************/
// Subract Bet from Bank
Function UpdatePlayerBank() {
	PlayerBank = PlayerBank - StringBetToAnalog();
	PlayerBankOut = PlayerBank;
}



/***********************************
Set Bets Structures By Type
***********************************/

//Add SPLIT Bet to Bet Structure
Function AddSplitBet(Integer Number1, Integer Number2){
	
	Trace("Storing SPLIT bet Index:%d with Numbers:%d and %d, with Bet:%d",CurrentBetArrayIndex, Number1, Number2, StringBetToAnalog());
	
	//Add to Bet Structure
	PlayerBets[CurrentBetArrayIndex].BetType = "Split";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Number1;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Split";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Number2;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("Current Bet Index: %d", CurrentBetArrayIndex);
	//AddToTotalBet(NewBet);
	
	//Update Player Bank
	UpdatePlayerBank();	
 
}

//Add STRAIGHT Bet to Bet Structure
Function AddStraightBet(Integer NumberToBet){
	
	Trace("Storing STRAIGHT bet Index:%d with Number:%d and Bet:%d",CurrentBetArrayIndex, NumberToBet, StringBetToAnalog());
	
	//Add to Bet Structure
	PlayerBets[CurrentBetArrayIndex].BetType = "Straight";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = NumberToBet;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("New bet index: %d", CurrentBetArrayIndex);
	
	//Update Player Bank
	UpdatePlayerBank();
}

//Add CORNER Bet to Bet Structure
Function AddCornerBet(Integer Num1, Integer Num2, Integer Num3, Integer Num4){

Trace("Storing CORNER bet Index:%d with Numbers:%d, %d, %d, and %d, with Bet:%d",CurrentBetArrayIndex, Num1, Num2, Num3, Num4, StringBetToAnalog());
	
	//Add to Bet Structure
	PlayerBets[CurrentBetArrayIndex].BetType = "Corner";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num1;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Corner";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num2;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Corner";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num3;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	PlayerBets[CurrentBetArrayIndex].BetType = "Corner";
	PlayerBets[CurrentBetArrayIndex].NumberPlayed = Num4;
	PlayerBets[CurrentBetArrayIndex].BetAmount = StringBetToAnalog();
	BetsRemaining = BetsRemaining - 1;
	BetCount = BetsRemaining;
	
	//Update Bet Index
	CurrentBetArrayIndex = CurrentBetArrayIndex + 1;
	Trace("Current Bet Index: %d", CurrentBetArrayIndex);
	//AddToTotalBet(NewBet);
	
	//Update Player Bank
	UpdatePlayerBank();
}


//Add STREET Bet to Bet Structure
Function AddStreetBet(Integer Num1, Integer Num2, Integer Num3){
Trace("Storing Street bet Index:%d with Numbers:%d, %d, and %d, with Bet:%d",CurrentBetArrayIndex, Num1, Num2, Num3, StringBetToAnalog());
	
	//Add to Bet Structure
