Function CheckOddBets(integer bet){

	integer index;
	
	for(index = 1 to 18){
	//Trace("Checking OddArray position %d. Position %d is: %d",index, index, OddArray[index]);
		if(OddArray[index] = bet){
		//Trace("There is a match at position %d!", index);
			Odd = 1;
		}
	}
}

Function CheckEvenBets(integer bet){
	integer index;
	
	for(index = 1 to 18){
	//Trace("Checking EvenArray position %d. Position %d is: %d",index, index, EvenArray[index]);
		if(EvenArray[index] = bet){
		//Trace("There is a match at position %d!", index);
			Even = 1;
		}
	}
}

Function CheckBlackOrRed(integer number){
	Integer index;
	Integer isMatch;
	isMatch = 0;
   
	if(number != 0){
	for(index = 1 to 18){
		//Trace("The black numbers are %d", Blacks.Number[index]);
		if(number = Blacks.Number[index])
		{
		isMatch = 1;
		}
	}
	
	if (isMatch = 1){
		Black = 1;
	}
	else {
		Red = 1;
	}
	}
}

Function CheckTwelves(integer number) {
	FirstTwelve = 0;
	SecondTwelve = 0;
	ThirdTwelve = 0;

	if (number >= 1 && number <= 12){
  		FirstTwelve = 1;
  	}
 	else if (number >= 13 && number <= 24){
 		SecondTwelve = 1;
 	}
 	else if (number >= 25 && number <= 36){
 		ThirdTwelve = 1;
 	}
}

Function CheckColumns(integer number){
	Integer index;

    for(index = 1 to 12){
    	if (number = ColumnOneArray[index]){
    		ColumnOne = 1;
    	}
		else if (number = ColumnTwoArray[index]){
    		ColumnTwo = 1;
    	}
    	else if (number = ColumnThreeArray[index]){
    		ColumnThree = 1;
    	}
    }    		
}

/*******************************************************************************************
  Event Handlers
*******************************************************************************************/
PUSH ResetOutputs {
	Odd = 0;
	Even = 0;
	Black = 0;
	Red = 0;
	FirstTwelve = 0;
	SecondTwelve = 0;
	ThirdTwelve = 0;
	ColumnOne = 0;
	ColumnTwo = 0;
	ColumnThree = 0;
	Zero = 0;
	DblZero = 0;
}

CHANGE WinningNumber{

	integer number;
	number = WinningNumber;
	
	If(number = 0){
	Zero = 1;}
	if(number = 37){
	DblZero = 1;}
	
	if(number !=0 && number != 37){
	Trace("Checking %d...",number);
	CheckOddBets(number);
	CheckEvenBets(number);
	CheckBlackOrRed(number);
	CheckTwelves(number);
	CheckColumns(number);
	}
	WinningNumberOut = number;
	

}

/*******************************************************************************************
  Main()
*******************************************************************************************/
Function Main()
{
	WaitForInitializationComplete();
	BuildArrays();
}
