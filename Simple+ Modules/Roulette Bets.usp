/*******************************************************************************************
  Compiler Directives
*******************************************************************************************/
#HINT "Helps with identifying winning number"	//Appears at the bottom of SimplWindows
#ENABLE_TRACE	//Makes trace statements work.
#CATEGORY "46" "Game" // Custom

/*******************************************************************************************
  DIGITAL, ANALOG and SERIAL INPUTS and OUTPUTS
*******************************************************************************************/
DIGITAL_INPUT	ResetOutputs;
ANALOG_INPUT	WinningNumber;
Digital_Output	Odd,
				Even,
				Black,
				Red,
				FirstTwelve,
				SecondTwelve,
				ThirdTwelve,
				ColumnOne,
				ColumnTwo,
				ColumnThree,
				Zero,
				DblZero;
Analog_Output	WinningNumberOut;

/*******************************************************************************************
  Structure Definitions
*******************************************************************************************/
STRUCTURE BlackNumbers
{
Integer Number[18];
};

Structure Streets
{
Integer Col1;
Integer Col2;
Integer Col3;
};



/*******************************************************************************************
  Global Variables
*******************************************************************************************/
INTEGER AllArray[37],
		BetsArray[100],
		OddArray[18],
		EvenArray[18],
		FirstTwelveArray[12],
		SecondTwelveArray[12],
		ThirdTwelveArray[12],
		ColumnOneArray[12],
		ColumnTwoArray[12],
		ColumnThreeArray[12];
		
BlackNumbers Blacks;
Streets Row[12];
/*******************************************************************************************
  Functions
*******************************************************************************************/

Function BuildArrays()
{
Integer index;
Integer	currentOdd;
Integer	currentEven;
Integer	FirstTwelveNum;
Integer	SecondTwelveNum;
Integer	ThirdTwelveNum;
Integer ColOneStart;
Integer ColTwoStart;
Integer ColThreeStart;
currentOdd = 1;
currentEven = 2;
FirstTwelveNum = 1;
SecondTwelveNum = 13;
ThirdTwelveNum = 25;
ColOneStart = 1;
ColTwoStart = 2;
ColThreeStart = 3;


	for(index = 1 to 37){
	AllArray[index] = index - 1;
	}
		
	for(index = 1 to 18){
	OddArray[index] = currentOdd;
	currentOdd = currentOdd + 2;
	}
	
	for(index = 1 to 18){
	EvenArray[index] = currentEven;
	currentEven = currentEven + 2;
	}
	
	for(index = 1 to 12){
	FirstTwelveArray[index] = FirstTwelveNum;
	FirstTwelveNum = FirstTwelveNum + 1;
	}
	
	for(index = 1 to 12){
	SecondTwelveArray[index] = SecondTwelveNum;
	SecondTwelveNum = SecondTwelveNum + 1;
	}
	
	for(index = 1 to 12){
	ThirdTwelveArray[index] = ThirdTwelveNum;
	ThirdTwelveNum = ThirdTwelveNum + 1;
	}
	
	for(index = 1 to 12){
	ColumnOneArray[index] = ColOneStart;
	ColOneStart = ColOneStart + 3;
	}
	
	for(index = 1 to 12){
	ColumnTwoArray[index] = ColTwoStart;
	ColTwoStart = ColTwoStart + 3;
	}
	
	for(index = 1 to 12){
	ColumnThreeArray[index] = ColThreeStart;
	ColThreeStart = ColThreeStart + 3;
	}
	
Blacks.Number[1]	= 2;
Blacks.Number[2]	= 4;
Blacks.Number[3]	= 6;
Blacks.Number[4]	= 8;
Blacks.Number[5]	= 10;
Blacks.Number[6]	= 11;
Blacks.Number[7]	= 13;
Blacks.Number[8]	= 15;
Blacks.Number[9]	= 17;
Blacks.Number[10]	= 20;
Blacks.Number[11]	= 22;
Blacks.Number[12]	= 24;
Blacks.Number[13]	= 26;
Blacks.Number[14]	= 28;
Blacks.Number[15]	= 29;
Blacks.Number[16]	= 31;
Blacks.Number[17]	= 33;
Blacks.Number[18]	= 35;

}

